// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  docente
}

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  password_hash String
  role          Role     @default(docente)
  created_at    DateTime @default(now())
  attempts      Attempt[]

  @@map("users")
}

model Exam {
  id              String     @id @default(uuid())
  title           String
  description     String?
  durationMinutes Int
  createdAt       DateTime   @default(now())
  questions       Question[]
  attempts        Attempt[]

  @@map("exams")
}

model Competency {
  id          String     @id @default(uuid())
  name        String
  description String?
  questions   Question[]

  @@map("competencies")
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  OPEN
}

model Question {
  id             String       @id @default(uuid())
  examId         String
  competencyId   String
  type           QuestionType
  questionText   String
  correctAnswer  String?
  points         Int          @default(1)
  createdAt      DateTime     @default(now())
  
  exam           Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  competency     Competency   @relation(fields: [competencyId], references: [id], onDelete: Cascade)
  options        Option[]
  answers        Answer[]

  @@map("questions")
}

model Option {
  id          String   @id @default(uuid())
  questionId  String
  optionText  String
  isCorrect   Boolean  @default(false)
  
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("options")
}

model Attempt {
  id             String    @id @default(uuid())
  userId         String
  examId         String
  scoreTotal     Int?
  levelEstimated String?
  startedAt      DateTime  @default(now())
  finishedAt     DateTime?
  
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam           Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)
  answers        Answer[]

  @@map("attempts")
}

model Answer {
  id             String   @id @default(uuid())
  attemptId      String
  questionId     String
  answerText     String
  isCorrect      Boolean?
  scoreObtained  Int      @default(0)
  
  attempt        Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question       Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("answers")
}
